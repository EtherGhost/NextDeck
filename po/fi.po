msgstr "Avaa järjestelmäasetukset"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Account"
msgstr "Tili"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Server address"
msgstr "Palvelimen osoite"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "This app uses Ubuntu Touch Online Accounts. Edit this only if the system account did not expose the correct server address."
msgstr "Diese App verwendet Ubuntu Touch Online Accounts. Bearbeite dies nur, wenn das Systemkonto nicht die richtige Serveradresse bereitgestellt hat."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Available accounts"
msgstr "Verfügbare Konten"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "No Nextcloud account found"
msgstr "Kein Nextcloud-Konto gefunden"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Add a Nextcloud or ownCloud account in Ubuntu Touch System Settings > Accounts. Then return here and select it."
msgstr "Füge ein Nextcloud- oder ownCloud-Konto unter Ubuntu Touch Systemeinstellungen > Konten hinzu. Kehre danach hierher zurück und wähle es aus."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "How to add an account"
msgstr "So fügst du ein Konto hinzu"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Allow %1 in Ubuntu Touch account settings first"
msgstr "Erlaube zuerst %1 in den Ubuntu-Touch-Kontoeinstellungen"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Allowed for %1"
msgstr "Erlaubt für %1"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Nextcloud account discovered"
msgstr "Nextcloud-Konto gefunden"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Verifying account..."
msgstr "Konto wird geprüft..."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Verify selected account"
msgstr "Ausgewähltes Konto prüfen"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "How to allow this account"
msgstr "So erlaubst du dieses Konto"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Selected %1. Verifying authorization..."
msgstr "%1 ausgewählt. Autorisierung wird geprüft..."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Saved account selected. Verify again if needed."
msgstr "Gespeichertes Konto ausgewählt. Bei Bedarf erneut prüfen."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Select an account first."
msgstr "Wähle zuerst ein Konto aus."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Verifying Online Accounts authorization..."
msgstr "Online-Accounts-Autorisierung wird geprüft..."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "This account is not allowed for %1 yet. Open Ubuntu Touch System Settings > Accounts, allow %1 for this account, then return here."
msgstr "Dieses Konto ist für %1 noch nicht erlaubt. Öffne Ubuntu Touch Systemeinstellungen > Konten, erlaube %1 für dieses Konto und kehre hierher zurück."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Checking account permission for %1..."
msgstr "Kontoberechtigung für %1 wird geprüft..."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Open Ubuntu Touch System Settings manually, go to Accounts, add a Nextcloud or ownCloud account, then return to %1 and select it."
msgstr "Öffne Ubuntu Touch Systemeinstellungen manuell, gehe zu Konten, füge ein Nextcloud- oder ownCloud-Konto hinzu und kehre zu %1 zurück, um es auszuwählen."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Open Ubuntu Touch System Settings manually, go to Accounts, select %1, allow %2 for that account, then return here. %2 will verify it automatically."
msgstr "Öffne Ubuntu Touch Systemeinstellungen manuell, gehe zu Konten, wähle %1, erlaube %2 für dieses Konto und kehre hierher zurück. %2 prüft es automatisch."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Open Ubuntu Touch System Settings manually, go to Accounts, select the Nextcloud account, allow %1 for that account, then return here. %1 will verify it automatically."
msgstr "Öffne Ubuntu Touch Systemeinstellungen manuell, gehe zu Konten, wähle das Nextcloud-Konto, erlaube %1 für dieses Konto und kehre hierher zurück. %1 prüft es automatisch."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Account permission detected. Verifying access..."
msgstr "Kontoberechtigung erkannt. Zugriff wird geprüft..."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Waiting for account permission. If you already allowed %1, return here and wait a moment."
msgstr "Warte auf Kontoberechtigung. Wenn du %1 bereits erlaubt hast, kehre hierher zurück und warte einen Moment."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "No account is saved yet. Select a Nextcloud account below, authorize it, and verify access."
msgstr "Es ist noch kein Konto gespeichert. Wähle unten ein Nextcloud-Konto, autorisiere es und prüfe den Zugriff."


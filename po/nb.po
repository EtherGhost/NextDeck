#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Authorization succeeded, but the Ubuntu Touch account did not expose a server address for %1."
msgstr "Godkendelsen lykkedes, men Ubuntu Touch-kontoen oplyste ikke en serveradresse for %1."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Authorization succeeded for %1. Credentials are available to the app, but were not displayed or stored."
msgstr "Godkendelsen lykkedes for %1. Loginoplysninger er tilgængelige for appen, men blev hverken vist eller gemt."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "%1 is not allowed to use this account yet. Open Ubuntu Touch System Settings > Accounts, allow %1 for this account, then return here."
msgstr "%1 må endnu ikke bruge denne konto. Åbn Ubuntu Touch Systemindstillinger > Konti, tillad %1 for denne konto, og vend tilbage hertil."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Authorization failed: %1. If the system did not show an Online Accounts prompt, open System Settings > Accounts and allow %2 for this account, then try again."
msgstr "Godkendelsen mislykkedes: %1. Hvis systemet ikke viste en Online Accounts-dialog, skal du åbne Systemindstillinger > Konti og tillade %2 for denne konto. Prøv derefter igen."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Allow account access"
msgstr "Tillat kontotilgang"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Open System Settings"
msgstr "Åpne systeminnstillinger"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Account"
msgstr "Konto"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Server address"
msgstr "Serveradresse"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "This app uses Ubuntu Touch Online Accounts. Edit this only if the system account did not expose the correct server address."
msgstr "Denne app bruger Ubuntu Touch Online Accounts. Rediger kun dette, hvis systemkontoen ikke oplyste den korrekte serveradresse."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Available accounts"
msgstr "Tilgængelige konti"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "No Nextcloud account found"
msgstr "Ingen Nextcloud-konto fundet"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Add a Nextcloud or ownCloud account in Ubuntu Touch System Settings > Accounts. Then return here and select it."
msgstr "Tilføj en Nextcloud- eller ownCloud-konto i Ubuntu Touch Systemindstillinger > Konti. Vend derefter tilbage hertil og vælg den."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "How to add an account"
msgstr "Sådan tilføjes en konto"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Allow %1 in Ubuntu Touch account settings first"
msgstr "Tillad først %1 i Ubuntu Touch-kontoindstillingerne"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Allowed for %1"
msgstr "Tilladt for %1"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Nextcloud account discovered"
msgstr "Nextcloud-konto fundet"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Verifying account..."
msgstr "Bekræfter konto..."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Verify selected account"
msgstr "Bekræft valgt konto"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "How to allow this account"
msgstr "Sådan tillades denne konto"

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Selected %1. Verifying authorization..."
msgstr "Valgte %1. Bekræfter godkendelse..."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Saved account selected. Verify again if needed."
msgstr "Gemt konto valgt. Bekræft igen om nødvendigt."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Select an account first."
msgstr "Vælg først en konto."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Verifying Online Accounts authorization..."
msgstr "Bekræfter Online Accounts-godkendelse..."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "This account is not allowed for %1 yet. Open Ubuntu Touch System Settings > Accounts, allow %1 for this account, then return here."
msgstr "Denne konto er endnu ikke tilladt for %1. Åbn Ubuntu Touch Systemindstillinger > Konti, tillad %1 for denne konto, og vend tilbage hertil."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Checking account permission for %1..."
msgstr "Kontrollerer kontotilladelse for %1..."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Open Ubuntu Touch System Settings manually, go to Accounts, add a Nextcloud or ownCloud account, then return to %1 and select it."
msgstr "Åbn Ubuntu Touch Systemindstillinger manuelt, gå til Konti, tilføj en Nextcloud- eller ownCloud-konto, og vend tilbage til %1 for at vælge den."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Open Ubuntu Touch System Settings manually, go to Accounts, select %1, allow %2 for that account, then return here. %2 will verify it automatically."
msgstr "Åbn Ubuntu Touch Systemindstillinger manuelt, gå til Konti, vælg %1, tillad %2 for kontoen, og vend tilbage hertil. %2 bekræfter automatisk."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Open Ubuntu Touch System Settings manually, go to Accounts, select the Nextcloud account, allow %1 for that account, then return here. %1 will verify it automatically."
msgstr "Åbn Ubuntu Touch Systemindstillinger manuelt, gå til Konti, vælg Nextcloud-kontoen, tillad %1 for den konto, og vend tilbage hertil. %1 bekræfter automatisk."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Account permission detected. Verifying access..."
msgstr "Kontotilladelse registreret. Bekræfter adgang..."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "Waiting for account permission. If you already allowed %1, return here and wait a moment."
msgstr "Venter på kontotilladelse. Hvis du allerede har tilladt %1, så vend tilbage hertil og vent et øjeblik."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "No account is saved yet. Select a Nextcloud account below, authorize it, and verify access."
msgstr "Der er endnu ikke gemt nogen konto. Vælg en Nextcloud-konto nedenfor, godkend den, og bekræft adgang."

#: vendor/NextCommon/qml/NextCommon/generated-release-audit
msgid "%1 on %2\nproviderId=%3 serviceId=%4"
msgstr "%1 på %2\nproviderId=%3 serviceId=%4"

